# ─── Safaricom Daraja credentials ────────────────────────────────────────────
# Get these from developer.safaricom.co.ke — requires a registered app (2FA needed)

# Consumer Key for your Daraja app
MPESA_CONSUMER_KEY=your_consumer_key_here

# Consumer Secret for your Daraja app
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Your M-Pesa shortcode. Sandbox default: 174379
MPESA_SHORTCODE=174379

# STK Push passkey. Sandbox public passkey below — replace only in production.
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# The HTTPS URL Safaricom will POST the callback to.
# Must be publicly reachable — use your ngrok dev domain.
# Example: https://abc123xyz.ngrok-free.dev/mpesa/callback
# HTTP works in sandbox but NOT in production. Must be HTTPS in production.
MPESA_CALLBACK_URL=https://YOUR-NGROK-DOMAIN.ngrok-free.dev/mpesa/callback

# 'sandbox' during development, 'production' when live
MPESA_ENVIRONMENT=sandbox

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Create the database first: createdb daraja_raw
DATABASE_URL=postgres://postgres:password@localhost:5432/daraja_raw

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on.
PORT=3000
